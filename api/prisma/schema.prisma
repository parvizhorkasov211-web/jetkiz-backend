generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT
  ADMIN
  COURIER
  RESTAURANT
}

model User {
  id    String   @id @default(uuid())
  phone String   @unique
  role  UserRole @default(CLIENT)

  // Auth OTP (для клиентов)
  otpCode      String?
  otpExpiresAt DateTime?

  // Auth password (для курьеров/админа)
  passwordHash String?
  isActive     Boolean @default(true)

  // Profile
  firstName String?
  lastName  String?
  email     String?
  avatarUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Opposite relations
  reviews Review[]
  orders  Order[]

  // Courier relations
  courierProfile       CourierProfile?
  courierNotesAuthored CourierNote[]   @relation("CourierNoteAuthor")
  courierReviews       CourierReview[]
}

enum RestaurantStatus {
  OPEN
  CLOSED
}

model Restaurant {
  id   String @id @default(uuid())
  slug String @unique

  nameRu        String
  nameKk        String
  descriptionRu String?
  descriptionKk String?

  coverImageUrl String?

  ratingAvg   Float @default(0)
  ratingCount Int   @default(0)

  status RestaurantStatus @default(OPEN)

  // Управление показом на главной
  isPinned  Boolean @default(false)
  sortOrder Int     @default(0)
  useRandom Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
  promos   Promo[]
  reviews  Review[]
  orders   Order[]

  @@index([isPinned, sortOrder])
  @@index([status])
}

model FoodCategory {
  id   String @id @default(uuid())
  code String @unique

  titleRu String
  titleKk String

  iconUrl   String?
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
  promos   Promo[]

  @@index([sortOrder])
}

model Product {
  id           String  @id @default(uuid())
  restaurantId String
  categoryId   String?

  titleRu       String
  titleKk       String
  descriptionRu String?
  descriptionKk String?

  price       Int
  imageUrl    String?
  isAvailable Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant    @relation(fields: [restaurantId], references: [id])
  category   FoodCategory? @relation(fields: [categoryId], references: [id])

  promos  Promo[]
  reviews Review[]

  orderItems OrderItem[]

  @@index([restaurantId])
  @@index([categoryId])
  @@index([isAvailable])
}

enum PromoTargetType {
  RESTAURANT
  PRODUCT
  CATEGORY
}

model Promo {
  id String @id @default(uuid())

  imageUrl String
  titleRu  String?
  titleKk  String?

  targetType PromoTargetType

  restaurantId String?
  productId    String?
  categoryId   String?

  isActive Boolean   @default(true)
  startsAt DateTime?
  endsAt   DateTime?

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant?   @relation(fields: [restaurantId], references: [id])
  product    Product?      @relation(fields: [productId], references: [id])
  category   FoodCategory? @relation(fields: [categoryId], references: [id])

  @@index([isActive, sortOrder])
  @@index([targetType])
  @@index([restaurantId])
  @@index([productId])
  @@index([categoryId])
}

model Review {
  id String @id @default(uuid())

  userId       String
  restaurantId String
  productId    String?

  orderId String? @unique

  rating Int
  text   String?

  createdAt DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  product    Product?   @relation(fields: [productId], references: [id])

  order Order? @relation(fields: [orderId], references: [id])

  @@index([restaurantId])
  @@index([productId])
  @@index([userId])
  @@index([orderId])
}

enum OrderStatus {
  CREATED
  PAID
  ACCEPTED
  COOKING
  READY
  ON_THE_WAY
  DELIVERED
  CANCELED
}

enum PaymentMethod {
  CARD
  CASH
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Order {
  id           String @id @default(uuid())
  userId       String
  restaurantId String

  status OrderStatus @default(CREATED)

  subtotal    Int
  deliveryFee Int
  total       Int

  addressId   String
  phone       String
  comment     String?
  leaveAtDoor Boolean @default(false)

  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)

  ratingGiven Boolean @default(false)

  // Courier assignment
  courierId   String?
  courierFee  Int    @default(0)
  assignedAt  DateTime?
  pickedUpAt  DateTime?
  deliveredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  courier CourierProfile? @relation(fields: [courierId], references: [userId])

  items  OrderItem[]
  review Review?

  // ✅ opposite side for CourierReview.order
  courierReview CourierReview? @relation("OrderCourierReview")

  @@index([userId])
  @@index([restaurantId])
  @@index([status])
  @@index([createdAt])

  @@index([courierId])
  @@index([assignedAt])
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String

  title    String
  price    Int
  quantity Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

/* =========================
   COURIERS
========================= */

model CourierProfile {
  userId String @id

  firstName String
  lastName  String
  iin       String

  // индивидуальный коэффициент (персональный), если null — берём глобальный тариф
  personalFeeOverride Int?

  // контроль активности
  isOnline       Boolean  @default(false)
  lastSeenAt     DateTime?
  lastActiveAt   DateTime?
  lastAssignedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  notes   CourierNote[]
  reviews CourierReview[]

  onlineEvents CourierOnlineEvent[]

  @@index([iin])
  @@index([isOnline])
}

model CourierTariff {
  id String @id @default(uuid())

  fee Int

  isActive Boolean @default(true)

  // планирование: можно заранее создать тариф с датой начала
  startsAt DateTime?
  endsAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, startsAt])
  @@index([createdAt])
  @@index([endsAt])
}

model CourierNote {
  id String @id @default(uuid())

  courierUserId String
  authorUserId  String?

  text String

  createdAt DateTime @default(now())

  courier CourierProfile @relation(fields: [courierUserId], references: [userId], onDelete: Cascade)
  author  User?          @relation("CourierNoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([courierUserId])
  @@index([authorUserId])
  @@index([createdAt])
}

model CourierReview {
  id String @id @default(uuid())

  courierUserId String
  userId        String

  orderId String? @unique

  rating Int
  text   String?

  createdAt DateTime @default(now())

  courier CourierProfile @relation(fields: [courierUserId], references: [userId], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ✅ named relation + opposite side exists in Order
  order Order? @relation("OrderCourierReview", fields: [orderId], references: [id], onDelete: SetNull)

  @@index([courierUserId])
  @@index([userId])
  @@index([createdAt])
}

model CourierOnlineEvent {
  id            String   @id @default(uuid())
  courierUserId String
  isOnline      Boolean
  at            DateTime @default(now())

  courier CourierProfile @relation(fields: [courierUserId], references: [userId], onDelete: Cascade)

  @@index([courierUserId, at])
  @@index([at])
}
