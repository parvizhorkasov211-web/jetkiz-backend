generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT
  ADMIN
  COURIER
  RESTAURANT
}

model User {
  id    String   @id @default(uuid())
  phone String   @unique
  role  UserRole @default(CLIENT)

  otpCode      String?
  otpExpiresAt DateTime?

  passwordHash String?
  isActive     Boolean @default(true)

  firstName String?
  lastName  String?
  email     String?
  avatarUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviews Review[]
  orders  Order[]

  courierProfile       CourierProfile?
  courierNotesAuthored CourierNote[]    @relation("CourierNoteAuthor")
  courierReviews       CourierReview[]
  addresses            Address[]
  promoCodeUsages      PromoCodeUsage[]

  restaurantPayoutsConfirmed RestaurantPayout[] @relation("RestaurantPayoutPaidByAdmin")
  courierPayoutsConfirmed    CourierPayout[]    @relation("CourierPayoutPaidByAdmin")

  @@index([role])
  @@index([isActive])
  @@index([createdAt])
}

enum RestaurantStatus {
  OPEN
  CLOSED
}

model Restaurant {
  id     String @id @default(uuid())
  slug   String @unique
  number Int    @unique @default(autoincrement())

  nameRu String
  nameKk String

  phone        String?
  address      String?
  workingHours String?

  descriptionRu String?
  descriptionKk String?

  coverImageUrl String?

  ratingAvg   Float @default(0)
  ratingCount Int   @default(0)

  status RestaurantStatus @default(OPEN)

  isInApp Boolean @default(true)

  restaurantCommissionPctOverride Int?

  isPinned  Boolean @default(false)
  sortOrder Int     @default(0)
  useRandom Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products   Product[]
  promos     Promo[]
  reviews    Review[]
  orders     Order[]
  categories FoodCategory[]
  promoCodes PromoCode[]

  payouts RestaurantPayout[]

  @@index([isPinned, sortOrder])
  @@index([status])
  @@index([number])
  @@index([isInApp])
  @@index([restaurantCommissionPctOverride])
}

model FoodCategory {
  id String @id @default(uuid())

  restaurantId String

  code String

  titleRu String
  titleKk String

  iconUrl   String?
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  products Product[]
  promos   Promo[]

  @@unique([restaurantId, code])
  @@index([restaurantId, sortOrder])
}

model Product {
  id          String  @id @default(uuid())
  titleRu     String
  titleKk     String
  price       Int
  imageUrl    String?
  isAvailable Boolean @default(true)

  restaurantId String
  categoryId   String?

  weight      String?
  composition String?
  description String?
  isDrink     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category   FoodCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  orderItems OrderItem[]

  images ProductImage[]

  @@index([restaurantId])
  @@index([categoryId])
  @@index([isAvailable])
  @@index([isDrink])
}

model ProductImage {
  id        String @id @default(uuid())
  productId String

  url       String
  isMain    Boolean @default(false)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, isMain])
  @@index([productId, sortOrder])
}

model Promo {
  id String @id @default(uuid())

  restaurantId String
  categoryId   String?

  titleRu String
  titleKk String
  textRu  String?
  textKk  String?

  imageUrl String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category   FoodCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([categoryId])
  @@index([isActive])
}

enum PromoCodeType {
  PERCENT
  FIXED
  FREE_DELIVERY
}

model PromoCode {
  id String @id @default(uuid())

  code String @unique

  type  PromoCodeType
  value Int           @default(0)

  isActive Boolean @default(true)

  startsAt  DateTime?
  expiresAt DateTime?

  usageLimit   Int?
  usedCount    Int  @default(0)
  perUserLimit Int?

  minOrderAmount    Int?
  maxDiscountAmount Int?

  firstOrderOnly Boolean @default(false)

  restaurantId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)

  usages PromoCodeUsage[]
  orders Order[]

  @@index([code])
  @@index([isActive])
  @@index([restaurantId])
  @@index([startsAt])
  @@index([expiresAt])
}

model PromoCodeUsage {
  id String @id @default(uuid())

  promoCodeId String
  userId      String
  orderId     String?

  discountAmount         Int @default(0)
  deliveryDiscountAmount Int @default(0)

  usedAt DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([promoCodeId])
  @@index([userId])
  @@index([orderId])
  @@index([usedAt])
}

model Review {
  id String @id @default(uuid())

  userId       String
  restaurantId String

  rating Int
  text   String?

  createdAt DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([restaurantId])
  @@index([createdAt])
}

model Address {
  id String @id @default(uuid())

  userId String

  title   String
  address String
  floor   String?
  door    String?
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  orders Order[]

  @@index([userId])
}

enum PaymentMethod {
  CASH
  CARD
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PricingSource {
  AUTO_DEFAULT
  AUTO_WEATHER
  MANUAL
}

model FinanceConfig {
  id String @id

  clientDeliveryFeeDefault Int @default(1200)
  clientDeliveryFeeWeather Int @default(1500)

  courierPayoutDefault Int @default(1100)
  courierPayoutWeather Int @default(1500)

  courierCommissionPctDefault Int @default(15)

  restaurantCommissionPctDefault Int @default(20)

  weatherEnabled Boolean @default(false)

  updatedAt DateTime @updatedAt
}

enum OrderStatus {
  CREATED
  ACCEPTED
  COOKING
  READY
  ON_THE_WAY
  DELIVERED
  CANCELED
  PAID
}

enum RestaurantPayoutStatus {
  PENDING
  PAID
  CANCELED
}

enum CourierPayoutStatus {
  PENDING
  PAID
  CANCELED
}

model Order {
  id String @id @default(uuid())

  number Int @unique @default(autoincrement())

  userId       String
  restaurantId String

  status OrderStatus @default(CREATED)

  subtotal               Int
  deliveryFee            Int
  discountAmount         Int @default(0)
  deliveryDiscountAmount Int @default(0)
  total                  Int

  promoCodeId String?
  promoCode   String?

  addressId   String
  phone       String
  comment     String?
  leaveAtDoor Boolean @default(false)

  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)

  ratingGiven Boolean @default(false)

  courierId   String?
  courierFee  Int       @default(0)
  assignedAt  DateTime?
  pickedUpAt  DateTime?
  deliveredAt DateTime?

  promisedAt DateTime?

  pricingSource       PricingSource @default(AUTO_DEFAULT)
  courierBonusApplied Int           @default(0)

  courierFeeGross             Int @default(0)
  courierCommissionPctApplied Int @default(0)
  courierCommissionAmount     Int @default(0)

  restaurantCommissionPctApplied Int @default(0)
  restaurantCommissionAmount     Int @default(0)
  restaurantPayoutAmount         Int @default(0)

  restaurantPayoutId String?
  courierPayoutId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  address Address @relation(fields: [addressId], references: [id], onDelete: Cascade)

  courier CourierProfile? @relation(fields: [courierId], references: [userId])

  promoCodeRef PromoCode? @relation(fields: [promoCodeId], references: [id])

  restaurantPayout RestaurantPayout? @relation(fields: [restaurantPayoutId], references: [id], onDelete: SetNull)
  courierPayout    CourierPayout?    @relation(fields: [courierPayoutId], references: [id], onDelete: SetNull)

  items           OrderItem[]
  promoCodeUsages PromoCodeUsage[]

  courierReview CourierReview? @relation("OrderCourierReview")

  courierLedgerEntries CourierLedgerEntry[]

  @@index([userId])
  @@index([restaurantId])
  @@index([status])
  @@index([createdAt])
  @@index([deliveredAt])
  @@index([courierId])
  @@index([assignedAt])
  @@index([addressId])
  @@index([number])
  @@index([pricingSource])
  @@index([promisedAt])
  @@index([promoCodeId])
  @@index([promoCode])
  @@index([restaurantPayoutId])
  @@index([courierPayoutId])
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String

  title    String
  price    Int
  quantity Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model RestaurantPayout {
  id           String @id @default(uuid())
  restaurantId String

  periodFrom DateTime
  periodTo   DateTime

  ordersCount Int @default(0)

  grossSubtotal    Int @default(0)
  commissionAmount Int @default(0)
  payoutAmount     Int @default(0)

  status RestaurantPayoutStatus @default(PENDING)
  paidAt DateTime?
  note   String?

  paymentReference String?
  paymentComment   String?
  paidByAdminId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant  Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders      Order[]
  paidByAdmin User?      @relation("RestaurantPayoutPaidByAdmin", fields: [paidByAdminId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([status])
  @@index([paidAt])
  @@index([periodFrom, periodTo])
  @@index([paidByAdminId])
}

model CourierPayout {
  id            String @id @default(uuid())
  courierUserId String

  periodFrom DateTime
  periodTo   DateTime

  ordersCount Int @default(0)

  grossAmount      Int @default(0)
  commissionAmount Int @default(0)
  payoutAmount     Int @default(0)

  status CourierPayoutStatus @default(PENDING)
  paidAt DateTime?
  note   String?

  paymentReference String?
  paymentComment   String?
  paidByAdminId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courier     CourierProfile @relation(fields: [courierUserId], references: [userId], onDelete: Cascade)
  orders      Order[]
  paidByAdmin User?          @relation("CourierPayoutPaidByAdmin", fields: [paidByAdminId], references: [id], onDelete: SetNull)

  @@index([courierUserId])
  @@index([status])
  @@index([paidAt])
  @@index([periodFrom, periodTo])
  @@index([paidByAdminId])
}

/**
 * =========================
 * COURIERS
 * =========================
 */

model CourierProfile {
  userId String @id

  number Int @unique @default(autoincrement())

  lat Float?
  lng Float?

  firstName String
  lastName  String
  iin       String

  addressText String?
  comment     String?

  blockedAt   DateTime?
  blockReason String?

  personalFeeOverride Int?

  payoutBonusAdd Int @default(0)

  courierCommissionPctOverride Int?

  isOnline       Boolean   @default(false)
  lastSeenAt     DateTime?
  lastActiveAt   DateTime?
  lastAssignedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  notes   CourierNote[]
  reviews CourierReview[]

  onlineEvents CourierOnlineEvent[]

  ledgerEntries CourierLedgerEntry[]
  payouts       CourierPayout[]

  @@index([iin])
  @@index([isOnline])
  @@index([number])
  @@index([lastSeenAt])
  @@index([lastActiveAt])
}

model CourierTariff {
  id String @id @default(uuid())

  fee Int

  isActive Boolean @default(true)

  startsAt DateTime?
  endsAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, startsAt])
  @@index([createdAt])
  @@index([endsAt])
}

model CourierNote {
  id String @id @default(uuid())

  courierUserId String
  authorUserId  String?

  text String

  createdAt DateTime @default(now())

  courier CourierProfile @relation(fields: [courierUserId], references: [userId], onDelete: Cascade)
  author  User?          @relation("CourierNoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([courierUserId])
  @@index([authorUserId])
  @@index([createdAt])
}

model CourierReview {
  id String @id @default(uuid())

  courierUserId String
  userId        String

  orderId String? @unique

  rating Int
  text   String?

  createdAt DateTime @default(now())

  courier CourierProfile @relation(fields: [courierUserId], references: [userId], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  order Order? @relation("OrderCourierReview", fields: [orderId], references: [id], onDelete: SetNull)

  @@index([courierUserId])
  @@index([userId])
  @@index([createdAt])
}

model CourierOnlineEvent {
  id String @id @default(uuid())

  courierUserId String

  isOnline Boolean
  source   String

  at DateTime @default(now())

  courier CourierProfile @relation(fields: [courierUserId], references: [userId], onDelete: Cascade)

  @@index([courierUserId, at])
  @@index([at])
  @@index([source])
}

/**
 * =========================
 * COURIER LEDGER (FINANCE)
 * =========================
 */

enum LedgerType {
  ORDER_PAYOUT
  BONUS
  PENALTY
  MANUAL_ADJUSTMENT
  PAYOUT
  SERVICE_COMMISSION
}

model CourierLedgerEntry {
  id            String     @id @default(uuid())
  courierUserId String
  orderId       String?
  type          LedgerType
  amount        Int
  comment       String?
  createdAt     DateTime   @default(now())

  courier CourierProfile @relation(fields: [courierUserId], references: [userId], onDelete: Cascade)
  order   Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([courierUserId, createdAt])
  @@index([orderId])
  @@index([type])
}

model HomeCmsConfig {
  id String @id

  promoTitleRu String?
  promoTitleKk String?

  promoImageUrl String?
  promoIsActive Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories HomeCmsCategory[]
}

model HomeCmsCategory {
  id String @id @default(uuid())

  configId String

  titleRu String
  titleKk String

  imageUrl String?
  sortOrder Int @default(0)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  config HomeCmsConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId, sortOrder])
  @@index([isActive])
}