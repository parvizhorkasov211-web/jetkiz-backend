generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT
  ADMIN
  COURIER
  RESTAURANT
}

model User {
  id           String    @id @default(uuid())
  phone        String    @unique
  role         UserRole  @default(CLIENT)

  otpCode      String?
  otpExpiresAt DateTime?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
